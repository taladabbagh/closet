// Digital Wardrobe & Outfit Builder — database schema
//
// Design principles:
// - Every model is scoped by userId (multi-tenant ready, even though v1 is single-user).
// - Categories are fully user-defined and nested (self-referencing tree).
//   Root categories (parentId = null) act as "type groupings" (Clothing, Accessories, ...).
// - System filters are first-class typed columns on WardrobeItem (fast, indexable).
// - Custom fields use typed value columns (not a JSON blob) so the filtering
//   engine can build safe, indexed Prisma queries against them.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums — only for values with fixed system semantics.
// Everything user-vocabulary-driven (brand, style, occasion...) is free text.
// ---------------------------------------------------------------------------

enum Season {
  SPRING
  SUMMER
  FALL
  WINTER
  ALL_SEASON
}

enum LaundryStatus {
  CLEAN
  DIRTY
  IN_LAUNDRY
}

enum CustomFieldType {
  TEXT
  NUMBER
  BOOLEAN
  SELECT
  MULTI_SELECT
}

// ---------------------------------------------------------------------------
// User
// ---------------------------------------------------------------------------

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categories   Category[]
  items        WardrobeItem[]
  tags         Tag[]
  customFields CustomField[]
  outfits      Outfit[]
}

// ---------------------------------------------------------------------------
// Category — user-defined, nested tree. Nothing is hardcoded.
// ---------------------------------------------------------------------------

model Category {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name     String
  icon     String? // optional emoji / lucide icon name
  color    String? // optional hex accent
  position Int     @default(0) // manual ordering among siblings

  parentId String?
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Cascade)
  children Category[] @relation("CategoryTree")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items       WardrobeItem[]
  outfitSlots OutfitItem[]

  @@index([userId])
  @@index([parentId])
}

// ---------------------------------------------------------------------------
// WardrobeItem — system filter fields are typed columns.
// ---------------------------------------------------------------------------

model WardrobeItem {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name  String
  notes String?

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  // --- fixed system filters ---
  colors        String[]      @default([]) // an item can be multi-color
  brand         String?
  seasons       Season[]      @default([])
  occasions     String[]      @default([])
  style         String?
  materials     String[]      @default([])
  fit           String?
  pattern       String?
  price         Decimal?      @db.Decimal(10, 2)
  wearCount     Int           @default(0)
  lastWornAt    DateTime?
  laundryStatus LaundryStatus @default(CLEAN)
  isFavorite    Boolean       @default(false)
  isActive      Boolean       @default(true)
  purchaseDate  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  images            Image[]
  tags              Tag[]
  customFieldValues CustomFieldValue[]
  outfitItems       OutfitItem[]

  @@index([userId])
  @@index([userId, categoryId])
  @@index([userId, isFavorite])
  @@index([userId, laundryStatus])
  @@index([userId, brand])
}

// ---------------------------------------------------------------------------
// Image — Cloudinary-backed, multiple per item, ordered (position 0 = cover).
// ---------------------------------------------------------------------------

model Image {
  id     String       @id @default(cuid())
  itemId String
  item   WardrobeItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  url      String // Cloudinary secure_url
  publicId String // Cloudinary public_id (needed for deletion/transforms)
  width    Int?
  height   Int?
  position Int    @default(0)

  createdAt DateTime @default(now())

  @@index([itemId])
}

// ---------------------------------------------------------------------------
// Tag — free-form labels, many-to-many with items.
// ---------------------------------------------------------------------------

model Tag {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name String

  createdAt DateTime @default(now())

  items WardrobeItem[]

  @@unique([userId, name])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// Custom fields — user-defined attributes with typed values.
// One CustomFieldValue row per (field, item); the value lives in the column
// matching the field's type, keeping filtering strongly typed.
// ---------------------------------------------------------------------------

model CustomField {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name     String
  type     CustomFieldType
  options  String[]        @default([]) // allowed values for SELECT / MULTI_SELECT
  position Int             @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  values CustomFieldValue[]

  @@unique([userId, name])
  @@index([userId])
}

model CustomFieldValue {
  id      String       @id @default(cuid())
  fieldId String
  field   CustomField  @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  itemId  String
  item    WardrobeItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  // exactly one of these is populated, according to field.type
  valueText    String?
  valueNumber  Float?
  valueBoolean Boolean?
  valueOptions String[] @default([]) // SELECT stores one entry, MULTI_SELECT many

  @@unique([fieldId, itemId])
  @@index([itemId])
}

// ---------------------------------------------------------------------------
// Outfits — a set of items, each optionally assigned to a category "slot".
// ---------------------------------------------------------------------------

model Outfit {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name       String
  notes      String?
  isFavorite Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items OutfitItem[]

  @@index([userId])
  @@index([userId, isFavorite])
}

model OutfitItem {
  id       String       @id @default(cuid())
  outfitId String
  outfit   Outfit       @relation(fields: [outfitId], references: [id], onDelete: Cascade)
  itemId   String
  item     WardrobeItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  // the category "slot" this item fills in the outfit builder
  slotCategoryId String?
  slotCategory   Category? @relation(fields: [slotCategoryId], references: [id], onDelete: SetNull)

  position Int @default(0)

  @@unique([outfitId, itemId])
  @@index([itemId])
}
